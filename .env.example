# ── MinIO ────────────────────────────────────────────────────
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=changeme123
MINIO_ENDPOINT=http://minio:9000
MINIO_RAW_BUCKET=raw-facilities
MINIO_ICEBERG_BUCKET=iceberg-warehouse

# ── Trino ────────────────────────────────────────────────────
TRINO_HOST=trino
TRINO_PORT=8080
TRINO_USER=trino
TRINO_CATALOG=iceberg
TRINO_SCHEMA=kenya_health

# ── Airflow ──────────────────────────────────────────────────
AIRFLOW_UID=1000
AIRFLOW__CORE__EXECUTOR=CeleryExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres-airflow:5432/airflow
AIRFLOW__CELERY__BROKER_URL=redis://redis:6379/0
AIRFLOW__CELERY__RESULT_BACKEND=db+postgresql://airflow:airflow@postgres-airflow:5432/airflow
AIRFLOW__CORE__FERNET_KEY=changeme_generate_with_fernet
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW_WEBSERVER_SECRET_KEY=changeme_webserver_secret

# ── Airflow admin (used by airflow-init service) ─────────────
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_EMAIL=admin@example.com

# ── Exposed ports (lets you change ports without touching compose) ──
AIRFLOW_PORT=8080
TRINO_EXPOSED_PORT=8081
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
SUPERSET_PORT=8088

# ── Postgres (Airflow metadata) ──────────────────────────────
POSTGRES_AIRFLOW_USER=airflow
POSTGRES_AIRFLOW_PASSWORD=airflow
POSTGRES_AIRFLOW_DB=airflow

# ── Postgres (Superset metadata) ─────────────────────────────
POSTGRES_SUPERSET_USER=superset
POSTGRES_SUPERSET_PASSWORD=superset
POSTGRES_SUPERSET_DB=superset

# ── Superset ─────────────────────────────────────────────────
SUPERSET_SECRET_KEY=changeme_superset_secret
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASSWORD=admin
SUPERSET_ADMIN_EMAIL=admin@example.com

# ── MOH KMHFL API ────────────────────────────────────────────
KMHFL_BASE_URL=https://kmhfl.health.go.ke/api
KMHFL_TOKEN=

# ── KNBS ─────────────────────────────────────────────────────
KNBS_POPULATION_URL=https://www.knbs.or.ke/population-estimates

# ── HDX ──────────────────────────────────────────────────────
HDX_BASE_URL=https://data.humdata.org/api/3
HDX_KENYA_DATASET_ID=kenya-county-geojson
